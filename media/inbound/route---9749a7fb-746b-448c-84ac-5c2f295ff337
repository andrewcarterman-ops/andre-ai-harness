// app/api/realtime/route.ts - Server-Sent Events for Real-time Updates

import { NextRequest } from 'next/server';

// Store connected clients
const clients = new Map<string, ReadableStreamDefaultController>();

// GET /api/realtime - Establish SSE connection
export async function GET(request: NextRequest) {
  const clientId = crypto.randomUUID();
  
  const stream = new ReadableStream({
    start(controller) {
      clients.set(clientId, controller);
      
      // Send initial connection message
      const connectedMessage = `data: ${JSON.stringify({ 
        type: 'connected', 
        clientId,
        timestamp: new Date().toISOString()
      })}\n\n`;
      controller.enqueue(new TextEncoder().encode(connectedMessage));
      
      // Heartbeat to keep connection alive
      const heartbeat = setInterval(() => {
        try {
          const pingMessage = `data: ${JSON.stringify({ type: 'ping' })}\n\n`;
          controller.enqueue(new TextEncoder().encode(pingMessage));
        } catch (e) {
          // Client disconnected
          clearInterval(heartbeat);
          clients.delete(clientId);
        }
      }, 30000);
      
      // Cleanup on abort
      request.signal.addEventListener('abort', () => {
        clearInterval(heartbeat);
        clients.delete(clientId);
        console.log(`Client ${clientId} disconnected`);
      });
    },
    cancel() {
      clients.delete(clientId);
    },
  });

  return new Response(stream, {
    headers: {
      'Content-Type': 'text/event-stream',
      'Cache-Control': 'no-cache, no-transform',
      'Connection': 'keep-alive',
      'X-Accel-Buffering': 'no', // Disable nginx buffering
    },
  });
}

// Helper function to broadcast to all connected clients
export function broadcastToClients(data: any) {
  const message = `data: ${JSON.stringify(data)}\n\n`;
  const encoded = new TextEncoder().encode(message);
  
  clients.forEach((controller, clientId) => {
    try {
      controller.enqueue(encoded);
    } catch (e) {
      // Client disconnected, remove from map
      clients.delete(clientId);
    }
  });
}

// Get number of connected clients (for monitoring)
export function getConnectedClientCount(): number {
  return clients.size;
}

// Send message to specific client
export function sendToClient(clientId: string, data: any): boolean {
  const controller = clients.get(clientId);
  if (!controller) return false;
  
  try {
    const message = `data: ${JSON.stringify(data)}\n\n`;
    controller.enqueue(new TextEncoder().encode(message));
    return true;
  } catch (e) {
    clients.delete(clientId);
    return false;
  }
}
