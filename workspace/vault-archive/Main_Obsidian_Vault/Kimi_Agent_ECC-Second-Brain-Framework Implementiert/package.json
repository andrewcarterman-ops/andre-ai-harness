{
  "name": "ecc-second-brain-core",
  "version": "1.0.0",
  "description": "ECC-CORE for Second-Brain Framework - Error handling, logging, and CI/CD evaluation",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "eval": "pwsh -File ./scripts/eval-runner.ps1",
    "backup": "pwsh -File ./scripts/cmd-backup.ps1 -Action Backup",
    "restore": "pwsh -File ./scripts/cmd-backup.ps1 -Action Restore",
    "lint": "eslint .",
    "logs": "cat .logs/ecc-second-brain-$(date +%Y-%m-%d).log"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrew-openclaw/second-brain.git"
  },
  "keywords": [
    "second-brain",
    "obsidian",
    "knowledge-management",
    "ecc-core",
    "powershell",
    "ci-cd"
  ],
  "author": "Andrew Openclaw",
  "license": "MIT",
  "dependencies": {
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.10.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "powershell": ">=5.1"
  },
  "winston": {
    "level": "info",
    "transports": {
      "console": {
        "enabled": true,
        "colorize": true
      },
      "file": {
        "enabled": true,
        "filename": ".logs/ecc-second-brain-%DATE%.log",
        "datePattern": "YYYY-MM-DD",
        "maxSize": "10m",
        "maxFiles": "30d"
      }
    }
  }
}
