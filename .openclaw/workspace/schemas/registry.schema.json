{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://framework.local/schemas/registry.schema.json",
  "title": "Registry",
  "description": "Schema for registry YAML files",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["skill", "agent", "hook", "context"]
          },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["active", "inactive", "deprecated"]
          }
        }
      }
    }
  }
}
