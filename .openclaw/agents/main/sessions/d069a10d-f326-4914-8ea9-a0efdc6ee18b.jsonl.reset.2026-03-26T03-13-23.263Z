{"type":"message","id":"5ab1d14f","parentId":"9d39505b","timestamp":"2026-03-25T22:58:35.210Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Ich erstelle die GitHub Actions Workflows.","thinkingSignature":""},{"type":"toolCall","id":"tool_60vTm7UJLdzODWn71QVCX79L","name":"write","arguments":{"content":"name: CI\n\non:\n  push:\n    branches: [main, master]\n  pull_request:\n    branches: [main, master]\n\n# Prevent duplicate runs\nconcurrency:\n  group: ${{ github.workflow }}-${{ github.ref }}\n  cancel-in-progress: true\n\npermissions:\n  contents: read\n\njobs:\n  validate:\n    name: Validate Framework\n    runs-on: ubuntu-latest\n    timeout-minutes: 10\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Setup PowerShell\n        uses: PowerShell/PowerShell@v2\n        with:\n          pwsh-version: '7.4'\n\n      - name: Validate Registry Files\n        shell: pwsh\n        run: |\n          $errors = 0\n          \n          # Check YAML files\n          Get-ChildItem registry/*.yaml | ForEach-Object {\n            try {\n              $content = Get-Content $_.FullName -Raw\n              if (-not ($content -match \"^\\s*\\w+:\")) {\n                Write-Error \"Invalid YAML: $($_.Name)\"\n                $errors++\n              }\n            } catch {\n              Write-Error \"Failed to parse: $($_.Name)\"\n              $errors++\n            }\n          }\n          \n          # Check JSON files\n          Get-ChildItem registry/*.json -ErrorAction SilentlyContinue | ForEach-Object {\n            try {\n              $null = Get-Content $_.FullName | ConvertFrom-Json\n            } catch {\n              Write-Error \"Invalid JSON: $($_.Name)\"\n              $errors++\n            }\n          }\n          \n          if ($errors -gt 0) { exit 1 }\n          Write-Host \"✅ All registry files valid\"\n\n      - name: Check Required Files\n        shell: pwsh\n        run: |\n          $required = @(\n            \"registry/agents.yaml\",\n            \"registry/skills.yaml\",\n            \"registry/hooks.yaml\",\n            \"README.md\",\n            \"scripts/validate-complete.ps1\"\n          )\n          \n          $missing = $required | Where-Object { -not (Test-Path $_) }\n          \n          if ($missing) {\n            Write-Error \"Missing files: $($missing -join ', ')\"\n            exit 1\n          }\n          \n          Write-Host \"✅ All required files present\"\n\n      - name: Run Complete Validation\n        shell: pwsh\n        run: |\n          $result = .\\scripts\\validate-complete.ps1\n          exit $LASTEXITCODE\n\n  test:\n    name: Test Suite\n    runs-on: windows-latest\n    timeout-minutes: 15\n    needs: validate\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Setup PowerShell\n        uses: PowerShell/PowerShell@v2\n\n      - name: Run Eval Suite\n        shell: pwsh\n        run: |\n          .\\tests\\ci-eval-runner.ps1 -Suite all -CI\n\n  quality:\n    name: Quality Gate\n    runs-on: ubuntu-latest\n    timeout-minutes: 10\n    needs: [validate, test]\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Setup PowerShell\n        uses: PowerShell/PowerShell@v2\n\n      - name: Run Quality Gate\n        shell: pwsh\n        run: |\n          $result = .\\scripts\\cmd-quality-gate.ps1 -Mode strict\n          if ($result -ne 0) {\n            Write-Error \"Quality gate failed\"\n            exit 1\n          }\n\n      - name: Check Documentation\n        shell: pwsh\n        run: |\n          $docs = @(\"README.md\", \"FINAL-COMPLETE.md\")\n          $missing = $docs | Where-Object { -not (Test-Path $_) }\n          \n          if ($missing) {\n            Write-Error \"Missing documentation: $($missing -join ', ')\"\n            exit 1\n          }\n          \n          Write-Host \"✅ Documentation complete\"\n","file_path":"C:/Users/andre/.openclaw/workspace/.github/workflows/ci.yml"}},{"type":"toolCall","id":"tool_HSj3QQOc7lNLGM0IN2oF04Xa","name":"write","arguments":{"content":"name: Daily Health Check\n\non:\n  schedule:\n    - cron: '0 9 * * *'  # 9 AM UTC daily\n  workflow_dispatch:  # Manual trigger\n\npermissions:\n  contents: read\n\njobs:\n  health:\n    name: Framework Health\n    runs-on: ubuntu-latest\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Setup PowerShell\n        uses: PowerShell/PowerShell@v2\n\n      - name: Drift Check\n        shell: pwsh\n        run: |\n          .\\scripts\\drift-check.ps1\n          if ($LASTEXITCODE -ne 0) {\n            Write-Warning \"Drift detected - review recommended\"\n          }\n\n      - name: Backup Status\n        shell: pwsh\n        run: |\n          $backups = Get-ChildItem memory/backups -Directory -ErrorAction SilentlyContinue\n          if (-not $backups) {\n            Write-Warning \"No backups found\"\n          } else {\n            Write-Host \"✅ $($backups.Count) backups available\"\n          }\n\n      - name: Test Coverage\n        shell: pwsh\n        run: |\n          $evals = Get-ChildItem registry/eval-*.yaml\n          Write-Host \"Found $($evals.Count) eval configurations\"\n","file_path":"C:/Users/andre/.openclaw/workspace/.github/workflows/health-check.yml"}},{"type":"toolCall","id":"tool_ODee3krMdEtRImMLR8RQGKtH","name":"write","arguments":{"content":"name: Release\n\non:\n  push:\n    tags:\n      - 'v*.*.*'\n\npermissions:\n  contents: write\n\njobs:\n  release:\n    name: Create Release\n    runs-on: ubuntu-latest\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@v4\n\n      - name: Validate Version\n        shell: pwsh\n        run: |\n          $tag = \"${{ github.ref_name }}\"\n          $manifest = Get-Content registry/install-manifest.yaml -Raw\n          \n          if (-not ($manifest -match $tag)) {\n            Write-Error \"Version mismatch: tag $tag not found in manifest\"\n            exit 1\n          }\n          \n          Write-Host \"✅ Version validated: $tag\"\n\n      - name: Package Framework\n        shell: pwsh\n        run: |\n          $version = \"${{ github.ref_name }}\"\n          $packageName = \"modular-agent-framework-$version\"\n          \n          # Create package\n          Compress-Archive -Path @(\n            \"registry\",\n            \"agents\",\n            \"skills\",\n            \"contexts\",\n            \"schemas\",\n            \"scripts\",\n            \"tests\",\n            \"docs\",\n            \"README.md\",\n            \"LICENSE\"\n          ) -DestinationPath \"$packageName.zip\" -Force\n          \n          Write-Host \"✅ Package created: $packageName.zip\"\n\n      - name: Create Release\n        uses: softprops/action-gh-release@v1\n        with:\n          files: |\n            *.zip\n          generate_release_notes: true\n          draft: false\n          prerelease: false\n","file_path":"C:/Users/andre/.openclaw/workspace/.github/workflows/release.yml"}}],"api":"anthropic-messages","provider":"kimi-coding","model":"k2p5","usage":{"input":323,"output":1727,"cacheRead":185344,"cacheWrite":0,"totalTokens":187394,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774479476010}}
