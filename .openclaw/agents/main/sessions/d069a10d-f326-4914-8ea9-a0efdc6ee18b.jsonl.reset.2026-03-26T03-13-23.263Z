Sessions\n    sessions:\n      - session_id: \"SESSION-20260325-224500-001\"\n        date: \"2026-03-25\"\n        description: \"Phase 3 Session Store Implementierung\"\n        outcome: \"success\"\n    \n    # Genutzte Skills\n    skills:\n      - \"secure-api-client\"\n      - \"mission-control\"\n      - \"self-improving-andrew\"\n    \n    # Projekt-spezifische Pfade\n    paths:\n      docs: \"docs/modular-agent-framework/\"\n      sessions: \"memory/sessions/\"\n      learning: \"memory/self-improving/projects/proj-modular-agent/\"\n    \n    # Agent-Zuordnung\n    assigned_agents:\n      - \"andrew-main\"\n    \n    # Projekt-spezifisches Lernen\n    learning_config:\n      enabled: true\n      patterns_file: \"memory/self-improving/projects/proj-modular-agent/patterns.md\"\n      preferences_file: \"memory/self-improving/projects/proj-modular-agent/preferences.md\"\n      auto_extract: true\n    \n    # Tags\n    tags:\n      - \"architecture\"\n      - \"framework\"\n      - \"openclaw\"\n      - \"phase-3\"\n    \n    # Notizen\n    notes: |\n      Hauptprojekt für den kontrollierten Aufbau eines modularen\n      agentischen Frameworks. Strikte Phasenabfolge, keine\n      ungeprüften Übernahmen aus fremden Frameworks.\n\n# Projekt-Templates (für zukünftige Projekte)\ntemplates:\n  - id: \"template-web-app\"\n    name: \"Web Application\"\n    description: \"Standard-Template für Web-App-Projekte\"\n    default_skills:\n      - \"secure-api-client\"\n      - \"mission-control\"\n    default_paths:\n      docs: \"docs/{project-id}/\"\n      src: \"src/{project-id}/\"\n    \n  - id: \"template-data-analysis\"\n    name: \"Data Analysis\"\n    description: \"Template für Datenanalyse-Projekte\"\n    default_skills:\n      - \"secure-api-client\"\n    default_paths:\n      data: \"data/{project-id}/\"\n      notebooks: \"notebooks/{project-id}/\"\n\n# Global-Einstellungen\nglobals:\n  default_agent: \"andrew-main\"\n  sessions_auto_link: true\n  learning_enabled_by_default: true\n  archive_after_days: 365\n","file_path":"C:/Users/andre/.openclaw/workspace/registry/projects.yaml"}}],"api":"anthropic-messages","provider":"kimi-coding","model":"k2p5","usage":{"input":3056,"output":1146,"cacheRead":87808,"cacheWrite":0,"totalTokens":92010,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774475188803}}
