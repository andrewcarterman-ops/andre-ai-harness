{"type":"message","id":"f929977f","parentId":"4e858ec4","timestamp":"2026-03-26T00:19:05.170Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create the analysis script and command for this functionality.","thinkingSignature":""},{"type":"toolCall","id":"tool_TLUdA1cl5eQcHh7qD70UaoMu","name":"write","arguments":{"content":"#!/usr/bin/env pwsh\n# Knowledge Curator Analysis Tool\n# Analyzes Second Brain/Obsidian vault for connections, orphans, and quality\n\nparam(\n    [string]$VaultPath = \"C:\\Users\\andre\\.openclaw\\workspace\\second-brain\",\n    [switch]$Detailed,\n    [switch]$AutoDecide,\n    [string]$OutputPath = \"\"\n)\n\n$ErrorActionPreference = \"Stop\"\n\nImport-Module \"$PSScriptRoot/../../../scripts/lib/Logging.psm1\" -ErrorAction SilentlyContinue\nif (Get-Command Initialize-Logging -ErrorAction SilentlyContinue) {\n    Initialize-Logging -Component \"knowledge-curator\"\n}\n\nWrite-Host \"🧠 Knowledge Curator Analysis\" -ForegroundColor Cyan\nWrite-Host \"Vault: $VaultPath\" -ForegroundColor Gray\nWrite-Host \"\"\n\n# Initialize results\n$analysis = @{\n    timestamp = Get-Date -Format \"o\"\n    vault_path = $VaultPath\n    total_notes = 0\n    connected_notes = 0\n    orphaned_notes = 0\n    broken_links = 0\n    notes = @()\n    hubs = @()\n    orphans = @()\n    recommendations = @()\n}\n\n# Get all markdown files\n$allFiles = Get-ChildItem $VaultPath -Recurse -Filter \"*.md\" -ErrorAction SilentlyContinue\n$analysis.total_notes = $allFiles.Count\n\nWrite-Host \"Found $($allFiles.Count) notes\" -ForegroundColor Green\n\n# Analyze each note\nforeach ($file in $allFiles) {\n    $relativePath = $file.FullName.Substring($VaultPath.Length + 1)\n    $content = Get-Content $file.FullName -Raw -ErrorAction SilentlyContinue\n    \n    if (-not $content) { continue }\n    \n    # Extract metadata from YAML frontmatter\n    $frontmatter = @{}\n    if ($content -match \"^---\\s*\\n([\\s\\S]*?)\\n---\") {\n        $yamlContent = $matches[1]\n        # Simple YAML parsing\n        $yamlContent -split \"\\n\" | ForEach-Object {\n            if ($_ -match \"^(\\w+):\\s*(.+)\") {\n                $frontmatter[$matches[1]] = $matches[2]\n            }\n        }\n    }\n    \n    # Count backlinks (other files linking to this)\n    $backlinks = 0\n    $linkingFiles = @()\n    foreach ($otherFile in $allFiles) {\n        if ($otherFile.FullName -eq $file.FullName) { continue }\n        $otherContent = Get-Content $otherFile.FullName -Raw -ErrorAction SilentlyContinue\n        $fileNameWithoutExt = [System.IO.Path]::GetFileNameWithoutExtension($file.Name)\n        if ($otherContent -match \"\\[\\[.*?$fileNameWithoutExt.*?\\]\\]|\\[$fileNameWithoutExt\\]\") {\n            $backlinks++\n            $linkingFiles += $otherFile.Name\n        }\n    }\n    \n    # Count outgoing links\n    $outgoingLinks = ([regex]::Matches($content, \"\\[\\[(.*?)\\]\\]\")).Count\n    \n    # Check for tags\n    $tags = @()\n    if ($content -match \"tags:\\s*\\[(.*?)\\]\") {\n        $tags = $matches[1] -split \",\" | ForEach-Object { $_.Trim() }\n    }\n    \n    # Detect broken links\n    $brokenLinksInFile = 0\n    $linkMatches = [regex]::Matches($content, \"\\[\\[(.*?)\\]\\]\")\n    foreach ($match in $linkMatches) {\n        $linkedFile = $match.Groups[1].Value -replace \"\\|.*\", \"\"  # Remove alias\n        $linkedFile = $linkedFile.Trim()\n        $possiblePaths = @(\n            \"$VaultPath\\$linkedFile.md\",\n            \"$VaultPath\\01-Sessions\\$linkedFile.md\",\n            \"$VaultPath\\02-Areas\\$linkedFile.md\",\n            \"$VaultPath\\03-Resources\\$linkedFile.md\"\n        )\n        $found = $false\n        foreach ($path in $possiblePaths) {\n            if (Test-Path $path) { $found = $true; break }\n        }\n        if (-not $found) { $brokenLinksInFile++ }\n    }\n    $analysis.broken_links += $brokenLinksInFile\n    \n    # Evaluate importance\n    $importanceScore = 0\n    $importanceFactors = @()\n    \n    if ($backlinks -ge 5) { \n        $importanceScore += 3\n        $importanceFactors += \"High connectivity ($backlinks links)\"\n    } elseif ($backlinks -ge 2) {\n        $importanceScore += 2\n        $importanceFactors += \"Medium connectivity\"\n    }\n    \n    if ($tags -contains \"decision\" -or $tags -contains \"adr\") {\n        $importanceScore += 2\n        $importanceFactors += \"Is decision/ADR\"\n    }\n    \n    if ($frontmatter[\"type\"] -eq \"session\") {\n        $importanceScore += 1\n        $importanceFactors += \"Is session log\"\n    }\n    \n    if ($content.Length -gt 2000) {\n        $importanceScore += 1\n        $importanceFactors += \"Substantial content\"\n    }\n    \n    # Determine if orphaned\n    $isOrphan = ($backlinks -eq 0) -and ($frontmatter[\"type\"] -ne \"dashboard\")\n    if ($isOrphan) { $analysis.orphaned_notes++ }\n    else { $analysis.connected_notes++ }\n    \n    # Recommendation\n    $recommendation = \"KEEP\"\n    $reason = \"Active knowledge\"\n    \n    if ($isOrphan) {\n        if ($content.Length -lt 500 -and $frontmatter[\"type\"] -eq \"session\") {\n            $recommendation = \"DELETE\"\n            $reason = \"Orphaned, short session, no connections\"\n        } elseif ($content.Length -lt 300) {\n            $recommendation = \"DELETE\"\n            $reason = \"Empty/placeholder note\"\n        } else {\n            $recommendation = \"REVIEW\"\n            $reason = \"Orphaned but has content - consider linking or archiving\"\n        }\n    } elseif ($frontmatter[\"status\"] -eq \"completed\" -and $backlinks -le 1) {\n        $recommendation = \"ARCHIVE\"\n        $reason = \"Completed, low connectivity\"\n    }\n    \n    $noteInfo = [PSCustomObject]@{\n        file = $relativePath\n        name = $file.BaseName\n        backlinks = $backlinks\n        outgoing_links = $outgoingLinks\n        tags = $tags -join \", \"\n        size = $content.Length\n        importance_score = $importanceScore\n        importance_factors = $importanceFactors -join \"; \"\n        is_orphan = $isOrphan\n        broken_links = $brokenLinksInFile\n        recommendation = $recommendation\n        reason = $reason\n        linking_files = $linkingFiles\n    }\n    \n    $analysis.notes += $noteInfo\n}\n\n# Identify hub notes (top 10 by backlinks)\n$analysis.hubs = $analysis.notes | Sort-Object backlinks -Descending | Select-Object -First 10 | Select-Object name, backlinks, tags\n\n# Identify orphans for detailed review\n$analysis.orphans = $analysis.notes | Where-Object { $_.is_orphan -eq $true } | Select-Object name, size, recommendation, reason\n\n# Generate recommendations list\n$analysis.recommendations = @{\n    delete = $analysis.notes | Where-Object { $_.recommendation -eq \"DELETE\" } | Select-Object file, reason\n    archive = $analysis.notes | Where-Object { $_.recommendation -eq \"ARCHIVE\" } | Select-Object file, reason\n    review = $analysis.notes | Where-Object { $_.recommendation -eq \"REVIEW\" } | Select-Object file, reason\n}\n\n# Display Results\nWrite-Host \"`n📊 ANALYSIS RESULTS\" -ForegroundColor Cyan\nWrite-Host \"===================\" -ForegroundColor Cyan\nWrite-Host \"Total Notes: $($analysis.total_notes)\" -ForegroundColor White\nWrite-Host \"Connected: $($analysis.connected_notes) ($([math]::Round($analysis.connected_notes/$analysis.total_notes*100, 1))%)\" -ForegroundColor Green\nWrite-Host \"Orphaned: $($analysis.orphaned_notes) ($([math]::Round($analysis.orphaned_notes/$analysis.total_notes*100, 1))%)\" -ForegroundColor Yellow\nWrite-Host \"Broken Links: $($analysis.broken_links)\" -ForegroundColor $(if($analysis.broken_links -eq 0){\"Green\"}else{\"Red\"})\n\nWrite-Host \"`n🔗 TOP 10 HUB NOTES\" -ForegroundColor Cyan\n$analysis.hubs | Format-Table -AutoSize\n\nWrite-Host \"`n⚠️  ORPHANED NOTES REQUIRING ATTENTION\" -ForegroundColor Cyan\n$analysis.orphans | Format-Table -AutoSize\n\nWrite-Host \"`n🎯 RECOMMENDATIONS\" -ForegroundColor Cyan\nWrite-Host \"DELETE ($($analysis.recommendations.delete.Count) notes):\" -ForegroundColor Red\n$analysis.recommendations.delete | ForEach-Object { Write-Host \"  - $($_.file): $($_.reason)\" -ForegroundColor Gray }\n\nWrite-Host \"`nARCHIVE ($($analysis.recommendations.archive.Count) notes):\" -ForegroundColor Yellow\n$analysis.recommendations.archive | ForEach-Object { Write-Host \"  - $($_.file): $($_.reason)\" -ForegroundColor Gray }\n\nWrite-Host \"`nREVIEW ($($analysis.recommendations.review.Count) notes):\" -ForegroundColor Cyan\n$analysis.recommendations.review | ForEach-Object { Write-Host \"  - $($_.file): $($_.reason)\" -ForegroundColor Gray }\n\n# Save report\nif (-not $OutputPath) {\n    $OutputPath = \"$VaultPath/../analysis-report-$(Get-Date -Format 'yyyyMMdd-HHmm').json\"\n}\n$analysis | ConvertTo-Json -Depth 5 | Out-File $OutputPath -Encoding UTF8\nWrite-Host \"`n💾 Report saved: $OutputPath\" -ForegroundColor Green\n\n# Detailed output if requested\nif ($Detailed) {\n    Write-Host \"`n📋 ALL NOTES DETAILED\" -ForegroundColor Cyan\n    $analysis.notes | Sort-Object importance_score -Descending | Format-Table name, backlinks, importance_score, recommendation -AutoSize\n}\n\nWrite-Host \"`n✅ Analysis complete!\" -ForegroundColor Green\n","file_path":"C:/Users/andre/.openclaw/workspace/second-brain/scripts/analyze-vault.ps1"}}],"api":"anthropic-messages","provider":"kimi-coding","model":"kimi-k2-thinking","usage":{"input":113731,"output":2522,"cacheRead":103424,"cacheWrite":0,"totalTokens":219677,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774484228461}}
