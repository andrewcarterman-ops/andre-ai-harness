rdown\", \"hook\"],\n      \"trigger\": \"session termination\",\n      \"handler_file\": \"hooks/session-end.md\",\n      \"enabled\": true,\n      \"priority\": 100,\n      \"async\": false\n    }\n  ],\n  \"categories\": {\n    \"external-api\": [\"example-weather\"],\n    \"security\": [\"secure-api-client\"],\n    \"learning\": [\"self-improving-andrew\"],\n    \"tooling\": [\"mission-control\", \"mission-control-v2\"]\n  },\n  \"keyword_index\": {\n    \"weather\": [\"example-weather\"],\n    \"forecast\": [\"example-weather\"],\n    \"api\": [\"example-weather\", \"secure-api-client\"],\n    \"security\": [\"secure-api-client\"],\n    \"http\": [\"secure-api-client\"],\n    \"learning\": [\"self-improving-andrew\"],\n    \"feedback\": [\"self-improving-andrew\"],\n    \"tool\": [\"mission-control\", \"mission-control-v2\"],\n    \"skill\": [\"mission-control\", \"mission-control-v2\"],\n    \"session\": [\"session:start\", \"session:end\"],\n    \"agent\": [\"andrew-main\"],\n    \"chat\": [\"andrew-main\"]\n  },\n  \"search_config\": {\n    \"default_limit\": 5,\n    \"min_keyword_length\": 3,\n    \"case_sensitive\": false,\n    \"fuzzy_matching\": false,\n    \"priority_boost\": 10\n  },\n  \"examples\": [\n    {\"query\": \"weather\", \"expected_results\": [\"example-weather\"]},\n    {\"query\": \"api security\", \"expected_results\": [\"secure-api-client\", \"example-weather\"]},\n    {\"query\": \"learn from feedback\", \"expected_results\": [\"self-improving-andrew\"]},\n    {\"query\": \"create tool\", \"expected_results\": [\"mission-control\", \"mission-control-v2\"]},\n    {\"query\": \"session start\", \"expected_results\": [\"session:start\"]}\n  ]\n}\n","file_path":"C:/Users/andre/.openclaw/workspace/registry/search-index.json"}}],"api":"anthropic-messages","provider":"kimi-coding","model":"k2p5","usage":{"input":1169,"output":2025,"cacheRead":68864,"cacheWrite":0,"totalTokens":72058,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"to