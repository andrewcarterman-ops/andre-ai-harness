  \n  - id: \"mission-control\"\n    name: \"mission-control\"\n    description: \"Command center for creating, managing, and deploying tools\"\n    path: \"skills/mission-control\"\n    skill_file: \"skills/mission-control/SKILL.md\"\n    has_frontmatter: false\n    category: \"tooling\"\n    triggers: [\"tool\", \"create\", \"deploy\"]\n    status: \"active\"\n    \n  - id: \"mission-control-v2\"\n    name: \"mission-control-v2\"\n    description: \"Enhanced version of mission-control\"\n    path: \"skills/mission-control-v2\"\n    skill_file: \"skills/mission-control-v2/SKILL.md\"\n    has_frontmatter: false\n    category: \"tooling\"\n    triggers: [\"advanced tool\"]\n    status: \"active\"\n    note: \"Contains node_modules\"\n    \n  # NEW: 6 Skills from ECC\n  - id: \"python-patterns\"\n    name: \"python-patterns\"\n    description: \"Python best practices and patterns\"\n    path: \"skills/python-patterns\"\n    skill_file: \"skills/python-patterns/SKILL.md\"\n    has_frontmatter: true\n    category: \"language\"\n    triggers: [\"python\", \"pythonic\", \"py\"]\n    status: \"active\"\n    source: \"adapted-from-ecc\"\n    \n  - id: \"security-review\"\n    name: \"security-review\"\n    description: \"Security-focused code review patterns\"\n    path: \"skills/security-review\"\n    skill_file: \"skills/security-review/SKILL.md\"\n    has_frontmatter: true\n    category: \"security\"\n    triggers: [\"security\", \"vulnerability\", \"audit\"]\n    status: \"active\"\n    source: \"adapted-from-ecc\"\n    \n  - id: \"testing-patterns\"\n    name: \"testing-patterns\"\n    description: \"Testing best practices and TDD patterns\"\n    path: \"skills/testing-patterns\"\n    skill_file: \"skills/testing-patterns/SKILL.md\"\n    has_frontmatter: true\n    category: \"quality\"\n    triggers: [\"test\", \"testing\", \"tdd\"]\n    status: \"active\"\n    source: \"adapted-from-ecc\"\n    \n  - id: \"api-design\"\n    name: \"api-design\"\n    description: \"REST