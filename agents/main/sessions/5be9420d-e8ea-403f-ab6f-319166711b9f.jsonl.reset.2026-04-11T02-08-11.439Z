{"type":"message","id":"f37c7490","parentId":"08b6a44e","timestamp":"2026-04-10T23:04:25.432Z","message":{"role":"toolResult","toolCallId":"tool_LuEjDsAayGF7slerDjsHVgGE","toolName":"read","content":[{"type":"text","text":"# Skill Registry - Phase 2: Matt Pocock Enhancement\n# Auto-generiert aus skills/*/SKILL.md\n# Format: YAML 1.2\n\nversion: \"2.0\"\nlast_updated: \"2026-04-11T00:05:00+02:00\"\nauto_generated: false\ngenerator_version: \"2.0\"\n\n# Gesamtanzahl Skills\ncount: 16\n\nskills:\n  # ============================================\n  # PLANNING SKILLS (NEW - Matt Pocock Style)\n  # ============================================\n  - id: \"write-a-prd\"\n    name: \"write-a-prd\"\n    description: \"Create a Product Requirements Document through interactive user interview, codebase exploration, and module design. Use when user wants to write a PRD, create product requirements, or plan a new feature from scratch.\"\n    path: \"skills/write-a-prd\"\n    skill_file: \"skills/write-a-prd/SKILL.md\"\n    has_frontmatter: true\n    category: \"planning\"\n    triggers: [\"write prd\", \"product requirements\", \"prd\", \"plan feature\"]\n    status: \"active\"\n    source: \"matt-pocock-adapted\"\n    workflow_type: \"interactive\"\n\n  - id: \"grill-me\"\n    name: \"grill-me\"\n    description: \"Relentlessly interview the user about a plan or design until reaching shared understanding, resolving each branch of the decision tree. Use when user wants to stress-test a plan, get grilled on their design, mentions 'grill me', or before starting implementation to catch edge cases.\"\n    path: \"skills/grill-me\"\n    skill_file: \"skills/grill-me/SKILL.md\"\n    has_frontmatter: true\n    category: \"planning\"\n    triggers: [\"grill me\", \"stress test\", \"review plan\", \"edge cases\"]\n    status: \"active\"\n    source: \"matt-pocock-adapted\"\n    workflow_type: \"interactive\"\n\n  - id: \"plan-feature\"\n    name: \"plan-feature\"\n    description: \"Turn a feature idea into a phased implementation plan using vertical slices (tracer bullets). Use when user wants to break down a feature, create an implementation plan, plan phases, or mentions 'tracer bullets' or 'vertical slices'.\"\n    path: \"skills/plan-feature\"\n    skill_file: \"skills/plan-feature/SKILL.md\"\n    has_frontmatter: true\n    category: \"planning\"\n    triggers: [\"plan feature\", \"break down\", \"implementation plan\", \"tracer bullets\", \"vertical slices\", \"phases\"]\n    status: \"active\"\n    source: \"matt-pocock-adapted\"\n\n[221 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1775862265427}}
