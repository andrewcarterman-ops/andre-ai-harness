{"type":"message","id":"a92a05c8","parentId":"ce2b36a0","timestamp":"2026-04-09T03:18:37.844Z","message":{"role":"toolResult","toolCallId":"tool_EzFmUXGy5huX7umn21xrZOfP","toolName":"read","content":[{"type":"text","text":"﻿hooks:\n  session:end:\n    description: \"Sync mit SecondBrain\"\n    handler_file: \"hooks/session-end.ps1\"\n    enabled: true\n    priority: 100\r\n"}],"isError":false,"timestamp":1775704717843}}
{"type":"message","id":"08c72c34","parentId":"a92a05c8","timestamp":"2026-04-09T03:18:37.847Z","message":{"role":"toolResult","toolCallId":"tool_xJ9AFrr3mwSLbUNaMamhtmLI","toolName":"read","content":[{"type":"text","text":"# Hook Registry - Phase 1: Manual Execution\n# Phase 2: Automatic Hook Engine (geplant)\n# Format: YAML 1.2\n# Encoding: UTF-8\n\nversion: \"1.2\"\nlast_updated: \"2026-04-03T00:35:00+01:00\"\n\n# Ausführungsmodus\n# Phase 1: \"manual\" - Agent führt Hooks explizit aus\n# Phase 2: \"automatic\" - Hook-Engine fängt Events ab\nexecution_mode: \"manual\"\n\n# Dokumentation\narchitecture_decision: \"docs/adr/003-hook-execution-model.md\"\n\n# Hook-Engine Einstellungen (für Phase 2)\nengine:\n  enabled: false              # true wenn Phase 2 implementiert\n  max_recursion_depth: 3\n  log_hooks: true\n  fail_on_error: false\n  \n# Verfügbare Hooks mit ihren Handlern\n# In Phase 1 werden diese durch den Agenten manuell ausgeführt\nhooks:\n  session:start:\n    description: \"Wird beim Start einer neuen Session ausgeführt\"\n    trigger: \"session initialization\"\n    handler_file: \"hooks/session-start.md\"\n    enabled: true\n    priority: 100\n    async: false\n    phase: 1                  # In Phase 1 implementiert\n    \n    # Was dieser Hook tut (für manuelle Implementierung):\n    actions:\n      - name: \"validate_registry\"\n        description: \"Prüfe ob alle Registry-Dateien vorhanden und gültig\"\n        required: true\n      - name: \"create_session_entry\"\n        description: \"Erstelle Session-Eintrag in memory/sessions/\"\n        required: true\n      - name: \"load_context\"\n        description: \"Lade SOUL.md, USER.md, MEMORY.md\"\n        required: true\n      - name: \"log_session_start\"\n        description: \"Logge Session-Start in memory/hooks.log\"\n        required: true\n    \n  session:end:\n    description: \"Wird beim Ende einer Session ausgeführt\"\n    trigger: \"session termination\"\n    handler_file: \"hooks/session-end.md\"\n    enabled: true\n    priority: 100\n    async: false\n    phase: 1                  # In Phase 1 implementiert\n    \n    # Was dieser Hook tut (für manuelle Implementierung):\n    actions:\n      - name: \"update_session_metadata\"\n        description: \"Aktualisiere Duration, Message-Count\"\n        required: true\n      - name: \"write_daily_log\"\n        description: \"Schreibe in memory/YYYY-MM-DD.md\"\n        required: false\n      - name: \"log_session_end\"\n        description: \"Logge Session-Ende in memory/hooks.log\"\n        required: true\n      - name: \"cleanup_temp\"\n        description: \"Räume temporäre Dateien auf\"\n        required: false\n    \n    post_actions:\n      - name: \"sync-second-brain\"\n        command: \"second-brain/scripts/sync-openclaw-to-secondbrain.ps1\"\n        condition: \"session.duration_minutes > 10\"\n        enabled: true\n        phase: 1                # In Phase 1 implementiert\n    \n  review:post_execution:\n    description: \"Review nach Plan-Ausführung oder kritischen Operationen\"\n    trigger: \"post execution\"\n    handler_file: \"hooks/review-post-execution.md\"\n    enabled: true\n    priority: 150\n    async: false\n    phase: 2                  # Erst in Phase 2 verfügbar\n    note: \"Benötigt Hook-Engine für automatische Trigger-Erkennung\"\n    \n  # Zukünftige Hooks (Phase 2)\n  # Diese erfordern die automatische Hook-Engine\n  \n  message:pre:\n    description: \"Wird vor Verarbeitung einer Nachricht ausgeführt\"\n    trigger: \"message received\"\n    handler_file: \"hooks/message-pre.md\"\n    enabled: false\n    priority: 200\n    phase: 2\n    note: \"Erfordert Hook-Engine\"\n    \n  message:post:\n    description: \"Wird nach Verarbeitung einer Nachricht ausgeführt\"\n    trigger: \"message processed\"\n    handler_file: \"hooks/message-post.md\"\n    enabled: false\n    priority: 200\n    phase: 2\n    note: \"Erfordert Hook-Engine\"\n    \n  error:critical:\n    description: \"Wird bei kritischen Fehlern ausgeführt\"\n    trigger: \"critical error\"\n    handler_file: \"hooks/error-critical.md\"\n    enabled: false\n    priority: 999\n    phase: 2\n    note: \"Erfordert Hook-Engine\"\n\n# Manuelle Hook-Ausführung (Phase 1)\n# Diese Konfiguration steuert, wie Agents Hooks manuell ausführen\nmanual_execution:\n  # Soll der Agent Hooks automatisch prüfen?\n  auto_check: true\n  \n  # Welche Hooks sollen am Session-Start geprüft werden?\n  on_session_start:\n    - session:start\n  \n  # Welche Hooks sollen am Session-Ende geprüft werden?\n  on_session_end:\n    - session:end\n  \n  # Logging\n  log_execution: true\n  log_file: \"memory/hooks.log\"\n\n# Globale Hook-Variablen (verfügbar in allen Hooks)\nglobals:\n  workspace_path: \"C:/Users/andre/.openclaw/workspace\"\n  registry_path: \"C:/Users/andre/.openclaw/workspace/registry\"\n  agent_id: \"andrew-main\"\n  timestamp_format: \"ISO8601\"\n\n# Logging-Konfiguration\nlogging:\n  enabled: true\n  destination: \"memory/hooks.log\"\n  format: \"[{timestamp}] [{hook_id}] {status}: {message}\"\n  max_size: \"10MB\"\n  rotation: 5\n\n# Migration Tracking\nmigration:\n  phase_1_complete: true\n  phase_2_planned: true\n  phase_2_issue: \"TBD\"  # GitHub Issue für Phase 2\n"}],"isError":false,"timestamp":1775704717845}}
