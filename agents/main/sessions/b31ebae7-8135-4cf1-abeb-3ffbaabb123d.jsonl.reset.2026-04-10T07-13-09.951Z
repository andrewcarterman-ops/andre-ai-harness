{"type":"message","id":"34fd729b","parentId":"c2abc60c","timestamp":"2026-04-09T02:41:20.791Z","message":{"role":"toolResult","toolCallId":"tool_SLTB2c96aQW0U5UqJgD0e0zH","toolName":"read","content":[{"type":"text","text":".gitignore\n# ============================================\n# GITIGNORE - Mit Token & Secret Protection\n# ============================================\n\n# --- Umgebungsvariablen & Configs mit Secrets ---\n.env\n.env.local\n.env.*.local\n.env.development\n.env.production\n.env.test\n!.env.example\n\n# Config-Dateien die oft Secrets enthalten\nconfig.json\nsecrets.json\ncredentials.json\n*.credentials.json\nservice-account*.json\n\n# --- API Keys & Tokens (Pattern-basiert) ---\n# Generische Token-Patterns\n*token*\n*apikey*\n*api-key*\n*api_key*\n*secret*\n*password*\n*passwd*\n*private*\n\n# Spezifische Dateien\n*.pem\n*.key\n*.p12\n*.pfx\n*.crt\n*.cer\n*.der\nid_rsa\nid_rsa.pub\nid_dsa\nid_dsa.pub\nid_ecdsa\nid_ecdsa.pub\nid_ed25519\nid_ed25519.pub\n.known_hosts\n.ssh/\n\n# --- Cloud Provider Credentials ---\n# AWS\n.aws/\naws.credentials\n.aws-credentials\n\n# Azure\n.azure/\n*.publishsettings\n\n# GCP\ngcloud/\n*.gcloud.json\napplication_default_credentials.json\n\n# --- Database Credentials ---\n*.db\n*.sqlite\n*.sqlite3\ndatabase.yml\nmongod.conf\nredis.conf\n\n# --- AI/LLM Service Tokens ---\n.openai*\n.anthropic*\n.claude*\n.gemini*\n.cohere*\n.huggingface*\n*.openai.key\n*.anthropic.key\n\n# --- NPM/Node Tokens ---\n.npmrc\n.npmignore\n.yarnrc\n.yarn-integrity\n\n# --- Python Virtual Envs (können Secrets enthalten) ---\nvenv/\n.env/\n.venv/\nenv/\nENV/\n\n# --- IDE & Editor ---\n.idea/\n.vscode/\n*.swp\n*.swo\n*~\n.DS_Store\nThumbs.db\n\n# --- Logs & Temp ---\n*.log\nlogs/\ntmp/\ntemp/\n*.tmp\n*.temp\n\n# --- Build Output ---\ndist/\nbuild/\nnode_modules/\n__pycache__/\n*.pyc\n*.pyo\n*.egg-info/\n\n# --- Backup Dateien ---\n*.bak\n*.backup\n*.old\n*.orig\n\n# --- Lokale Test-Dateien ---\nlocal-test*\ntest-local*\ndev-only*\n"}],"isError":false,"timestamp":1775702480783}}
