w adapter\\n    pub fn new() -> Self {\\n        Self {\\n            manager: McpServerManager::new(),\\n        }\\n    }\\n    \\n    /// Start an MCP server and register its tools\\n    pub async fn start_server(\\n        &mut self,\\n        name: &str,\\n        command: &str,\\n        args: Vec<String>,\\n    ) -> Result<(), String> {\\n        self.manager.start_server(\\n            name,\\n            command,\\n            args,\\n            BTreeMap::new(),\\n        ).await.map_err(|e| e.message)\\n    }\\n    \\n    /// Get all tools from all MCP servers\\n    pub fn get_tools(&self) -> Vec<McpTool> {\\n        self.manager.get_all_tools()\\n            .into_iter()\\n            .map(|(_, tool)| tool)\\n            .collect()\\n    }\\n}\\n\",\"path\":\"C:\\\\Users\\\\andre\\\\.openclaw\\\\workspace\\\\crates\\\\ecc-runtime\\\\src\\\\mcp_integration.rs\"}},{\"type\":\"text\",\"text\":\"  \"}],\"api\":\"anthropic-messages\",\"provider\":\"kimi-coding\",\"model\":\"kimi-k2-thinking\",\"usage\":{\"input\":220653,\"output\":488,\"cacheRead\":0,\"cacheWrite\":0,\"totalTokens\":221141,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1775104006130}}\n{\"type\":\"message\",\"id\":\"a75736e9\",\"parentId\":\"2f2f6154\",\"timestamp\":\"2026-04-02T04:27:16.710Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"tool_oYBL2X0qfh8Phlccl5JOyZ9L\",\"toolName\":\"write\",\"content\":[{\"type\":\"text\",\"text\":\"Successfully wrote 1185 bytes to C:\\\\Users\\\\andre\\\\.openclaw\\\\workspace\\\\crates\\\\ecc-runtime\\\\src\\\\mcp_integration.rs\"}],\"isError\":false,\"timestamp\":1775104036706}}\n\n{\"type\":\"message\",\"id\":\"1645a7d2\",\"parentId\":\"a75736e9\",\"timestamp\":\"2026-04-02T04:27:34.337Z\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\" The user wants me to fix the errors NOW. Let me focus on making it compile correctly. I need to