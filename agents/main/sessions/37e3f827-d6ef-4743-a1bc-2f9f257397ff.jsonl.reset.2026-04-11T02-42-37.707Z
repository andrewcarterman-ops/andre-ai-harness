{"type":"message","id":"484f1ee2","parentId":"71d3537c","timestamp":"2026-04-10T13:54:18.449Z","message":{"role":"toolResult","toolCallId":"tool_x3pGBV5l1gVw1u9zkNAt9GOZ","toolName":"read","content":[{"type":"text","text":"# ECC Second Brain - Drift Detection Configuration\n# Referenz-Struktur für Vault-Validierung\n\nversion: \"1.0.0\"\ndescription: \"Reference structure for ECC Second Brain Vault\"\n\n# Tolerance Settings\ntolerance:\n  # Allow additional files not in reference\n  allow_extra_files: true\n  \n  # Allow missing optional files\n  allow_missing_optional: true\n  \n  # Maximum drift percentage before warning\n  max_drift_percent: 10\n\n# Required Folders (must exist)\nrequired_folders:\n  - path: \"00-Inbox\"\n    description: \"Quick capture zone for new inputs\"\n    optional: false\n  \n  - path: \"01-Projects\"\n    description: \"Active ECC projects\"\n    optional: false\n  \n  - path: \"02-Areas\"\n    description: \"Long-term areas of responsibility\"\n    optional: false\n  \n  - path: \"03-Resources\"\n    description: \"Reusable knowledge and resources\"\n    optional: false\n  \n  - path: \"03-Resources/Skills\"\n    description: \"Skills and competencies\"\n    optional: false\n  \n  - path: \"03-Resources/Patterns\"\n    description: \"Code patterns and best practices\"\n    optional: false\n  \n  - path: \"03-Resources/Snippets\"\n    description: \"Code snippets\"\n    optional: false\n  \n  - path: \"04-Archive\"\n    description: \"Completed sessions\"\n    optional: false\n  \n  - path: \"05-Daily\"\n    description: \"Daily session logs\"\n    optional: false\n  \n  - path: \"scripts\"\n    description: \"Automation scripts\"\n    optional: false\n  \n  - path: \"scripts/lib\"\n    description: \"PowerShell modules\"\n    optional: false\n  \n  - path: \"config\"\n    description: \"Configuration files\"\n    optional: false\n  \n  - path: \".logs\"\n    description: \"Log files\"\n    optional: true\n  \n  - path: \".backups\"\n    description: \"Backup files\"\n    optional: true\n  \n  - path: \".obsidian\"\n    description: \"Obsidian configuration\"\n    optional: false\n  \n  - path: \".obsidian/plugins/ecc-vault\"\n    description: \"ECC Vault plugin\"\n    optional: false\n  \n  - path: \".obsidian/snippets\"\n    description: \"CSS snippets\"\n    optional: true\n  \n  - path: \".obsidian/templates\"\n    description: \"Note templates\"\n    optional: false\n\n# Required Files (must exist)\nrequired_files:\n  - path: \"README.md\"\n    description: \"Main documentation\"\n    optional: false\n  \n  - path: \"Setup-SecondBrain.ps1\"\n    description: \"Setup script\"\n    optional: false\n  \n  - path: \"scripts/lib/ErrorHandler.psm1\"\n    description: \"Error handling module\"\n    optional: false\n  \n  - path: \"scripts/lib/Logging.psm1\"\n    description: \"Logging module\"\n    optional: false\n  \n  - path: \"scripts/lib/MermaidGenerator.psm1\"\n    description: \"Mermaid diagram generator\"\n    optional: false\n  \n  - path: \"scripts/lib/DataviewQuery.psm1\"\n    description: \"Dataview query generator\"\n    optional: false\n  \n  - path: \"scripts/lib/Encryption.psm1\"\n    description: \"Encryption module\"\n    optional: false\n  \n  - path: \"scripts/sync-openclaw-to-obsidian.ps1\"\n    description: \"Sync script\"\n    optional: false\n  \n  - path: \".obsidian/plugins/ecc-vault/manifest.json\"\n    description: \"Plugin manifest\"\n    optional: false\n  \n  - path: \".obsidian/plugins/ecc-vault/data.json\"\n    description: \"Plugin configuration\"\n    optional: false\n  \n  - path: \".obsidian/plugins/ecc-vault/styles.css\"\n    description: \"Plugin styles\"\n    optional: false\n  \n  - path: \".obsidian/templates/daily-note-template.md\"\n    description: \"Daily note template\"\n    optional: false\n  \n  - path: \".obsidian/templates/decision-template.md\"\n    description: \"Decision template\"\n    optional: false\n\n# File Patterns (must match at least one)\nrequired_patterns:\n  - pattern: \"00-Inbox/*.md\"\n    description: \"Inbox notes\"\n    min_count: 0\n    optional: true\n  \n  - pattern: \"01-Projects/*.md\"\n    description: \"Project notes\"\n    min_count: 0\n    optional: true\n  \n  - pattern: \"05-Daily/*.md\"\n    description: \"Daily notes\"\n    min_count: 0\n    optional: true\n\n# Auto-Fix Settings\nauto_fix:\n  enabled: true\n  actions:\n    - create_missing_folders\n    - create_missing_templates\n    - fix_permissions\n  \n  exclude:\n    - \".obsidian/workspace.json\"\n    - \".obsidian/graph.json\"\n    - \".logs/*\"\n    - \".backups/*\"\n\n# Reporting\nreport:\n  format: \"markdown\"\n  output: \".logs/drift-report.md\"\n  include_recommendations: true\n"}],"isError":false,"timestamp":1775829258441}}
{"type":"message","id":"0ec001d9","parentId":"484f1ee2","timestamp":"2026-04-10T13:54:18.455Z","message":{"role":"toolResult","toolCallId":"tool_N1qKrOJ1qgPMvlP5XcNF0xka","toolName":"read","content":[{"type":"text","text":"# ECC Second Brain - Eval Template\n# CI/CD Quality Gates für das Second Brain Framework\n\nversion: \"1.0.0\"\nname: \"ECC Second Brain Evaluation\"\ndescription: \"Quality gates for Second Brain framework validation\"\n\n# Test Suites\nsuites:\n  - name: \"Structure\"\n    description: \"Validate folder structure and required files\"\n    weight: 25\n    tests:\n      - name: \"Vault Structure\"\n        description: \"Check if all required folders exist\"\n        command: \"Test-Path\"\n        params:\n          paths:\n            - \"00-Inbox\"\n            - \"01-Projects\"\n            - \"02-Areas\"\n            - \"03-Resources\"\n            - \"04-Archive\"\n            - \"05-Daily\"\n            - \"scripts\"\n            - \"config\"\n            - \".logs\"\n            - \".backups\"\n            - \".obsidian\"\n        expected: true\n      \n      - name: \"PowerShell Modules\"\n        description: \"Check if all required modules exist\"\n        command: \"Test-Path\"\n        params:\n          paths:\n            - \"scripts/lib/ErrorHandler.psm1\"\n            - \"scripts/lib/Logging.psm1\"\n            - \"scripts/lib/MermaidGenerator.psm1\"\n            - \"scripts/lib/DataviewQuery.psm1\"\n            - \"scripts/lib/Encryption.psm1\"\n        expected: true\n      \n      - name: \"Obsidian Config\"\n        description: \"Check if Obsidian configuration exists\"\n        command: \"Test-Path\"\n        params:\n          paths:\n            - \".obsidian/plugins/ecc-vault/manifest.json\"\n            - \".obsidian/plugins/ecc-vault/data.json\"\n            - \".obsidian/plugins/ecc-vault/styles.css\"\n        expected: true\n\n  - name: \"Metadata\"\n    description: \"Validate YAML frontmatter in templates\"\n    weight: 25\n    tests:\n      - name: \"Daily Note Template\"\n        description: \"Check if daily note template has required fields\"\n        command: \"Test-Template\"\n        params:\n          file: \".obsidian/templates/daily-note-template.md\"\n          required_fields:\n            - \"session_id\"\n            - \"date\"\n            - \"tokens_used\"\n            - \"agent_mode\"\n            - \"key_decisions\"\n        expected: true\n      \n      - name: \"Decision Template\"\n        description: \"Check if decision template has required fields\"\n        command: \"Test-Template\"\n        params:\n          file: \".obsidian/templates/decision-template.md\"\n          required_fields:\n            - \"decision_id\"\n            - \"date\"\n            - \"status\"\n        expected: true\n\n  - name: \"Links\"\n    description: \"Validate internal links and references\"\n    weight: 25\n    tests:\n      - name: \"Template Links\"\n        description: \"Check if templates have valid links\"\n        command: \"Test-Links\"\n        params:\n          files:\n            - \".obsidian/templates/daily-note-template.md\"\n            - \".obsidian/templates/decision-template.md\"\n        expected: true\n      \n      - name: \"Dataview Queries\"\n        description: \"Check if Dataview queries are valid\"\n        command: \"Test-Dataview\"\n        params:\n          files:\n            - \"03-Resources/Dataview/queries.md\"\n        expected: true\n\n  - name: \"Quality\"\n    description: \"Code quality and best practices\"\n    weight: 25\n    tests:\n      - name: \"PowerShell Syntax\"\n        description: \"Validate PowerShell script syntax\"\n        command: \"Test-PSSyntax\"\n        params:\n          files:\n            - \"scripts/*.ps1\"\n            - \"scripts/lib/*.psm1\"\n        expected: true\n      \n      - name: \"JSON Validity\"\n        description: \"Validate JSON configuration files\"\n        command: \"Test-JSON\"\n        params:\n          files:\n            - \".obsidian/plugins/ecc-vault/*.json\"\n        expected: true\n      \n      - name: \"YAML Validity\"\n        description: \"Validate YAML configuration files\"\n        command: \"Test-YAML\"\n        params:\n          files:\n            - \"config/*.yaml\"\n        expected: true\n\n# Quality Gates\ngates:\n  - name: \"Minimum Score\"\n    threshold: 80\n    fail_on_breach: true\n  \n  - name: \"Critical Tests\"\n    tests:\n      - \"Vault Structure\"\n      - \"Obsidian Config\"\n    fail_on_breach: true\n\n# Reporting\nreport:\n  format: \"json\"\n  output: \".logs/eval-report.json\"\n  include_details: true\n  include_recommendations: true\n\n# Notifications\nnotifications:\n  on_failure: true\n  on_success: false\n  channels:\n    - \"console\"\n    - \"file\"\n"}],"isError":false,"timestamp":1775829258450}}
{"type":"message","id":"32fe3136","parentId":"0ec001d9","timestamp":"2026-04-10T13:54:18.461Z","message":{"role":"toolResult","toolCallId":"tool_TqA89WHkBo1tcz0yxVGyON4K","toolName":"read","content":[{"type":"text","text":"# ECC Second Brain - Stability Configuration\n# Token thresholds, backup settings, and retry configuration\n\nversion: \"1.0.0\"\ndescription: \"Stability configuration for ECC Second Brain Framework\"\n\n# Token Usage Thresholds\ntoken_thresholds:\n  warning: 70\n    # Percentage at which to show warning\n    action: \"log\"\n    message: \"Token usage at 70% - consider context switch soon\"\n  \n  compression: 80\n    # Percentage at which to trigger context compression\n    action: \"compress\"\n    message: \"Token usage at 80% - compressing context\"\n    compress_ratio: 0.5\n  \n  emergency: 90\n    # Percentage at which to trigger emergency context switch\n    action: \"emergency\"\n    message: \"Token usage at 90% - emergency context switch required\"\n    create_checkpoint: true\n\n# Backup Settings\nbackup:\n  enabled: true\n  \n  # Auto-backup before each session\n  auto_backup: true\n  \n  # Backup path\n  path: \".backups\"\n  \n  # Retention policy (days)\n  retention_days: 30\n  \n  # Compression level (0-9)\n  compression_level: 6\n  \n  # Include patterns\n  include:\n    - \"*.md\"\n    - \".obsidian/**/*.json\"\n    - \"scripts/**/*.ps1\"\n    - \"scripts/**/*.psm1\"\n    - \"config/**/*.yaml\"\n  \n  # Exclude patterns\n  exclude:\n    - \".logs/*\"\n    - \".backups/*\"\n    - \"node_modules/*\"\n    - \"*.tmp\"\n  \n  # Pre-session backup\n  pre_session:\n    enabled: true\n    include_working_files: true\n  \n  # Post-session backup\n  post_session:\n    enabled: true\n    only_on_changes: true\n\n# Retry Configuration\nretry:\n  # Default retry count\n  max_retries: 3\n  \n  # Base delay in seconds\n  base_delay_seconds: 2\n  \n  # Use exponential backoff\n  exponential_backoff: true\n  \n  # Maximum delay in seconds\n  max_delay_seconds: 60\n  \n  # Retryable operations\n  operations:\n    - \"sync\"\n    - \"backup\"\n    - \"restore\"\n    - \"encryption\"\n    - \"decryption\"\n\n# Context Switching\ncontext_switch:\n  enabled: true\n  \n  # Compression settings\n  compression:\n    enabled: true\n    ratio: 0.5\n    preserve_decisions: true\n    preserve_todos: true\n    preserve_insights: true\n  \n  # Checkpointing\n  checkpoint:\n    enabled: true\n    path: \".checkpoints\"\n    auto_create: true\n  \n  # Session resumption\n  resume:\n    enabled: true\n    load_last_checkpoint: true\n\n# Drift Detection\ndrift_detection:\n  enabled: true\n  \n  # Check interval (minutes)\n  check_interval: 60\n  \n  # Auto-fix enabled\n  auto_fix: false\n  \n  # Config file\n  config_file: \"config/drift-config.yaml\"\n\n# Logging\nlogging:\n  enabled: true\n  \n  # Log level\n  level: \"INFO\"\n  \n  # Log path\n  path: \".logs\"\n  \n  # Log rotation\n  rotation:\n    enabled: true\n    max_size_mb: 10\n    max_files: 10\n  \n  # Console output\n  console:\n    enabled: true\n    colors: true\n\n# Security\nsecurity:\n  # API key encryption\n  encrypt_api_keys: true\n  \n  # Key storage\n  key_storage: \".obsidian/plugins/ecc-vault/secure-keys.json\"\n  \n  # Master key protection\n  master_key_protection: true\n  \n  # File permissions\n  file_permissions:\n    enabled: true\n    restrict_to_owner: true\n\n# Performance\nperformance:\n  # Parallel processing\n  parallel_processing: true\n  max_threads: 4\n  \n  # Caching\n  caching:\n    enabled: true\n    ttl_seconds: 300\n  \n  # Memory limits\n  memory:\n    max_mb: 512\n    cleanup_threshold: 80\n"}],"isError":false,"timestamp":1775829258456}}
