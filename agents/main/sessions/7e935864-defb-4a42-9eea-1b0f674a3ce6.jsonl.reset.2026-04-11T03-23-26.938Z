e\n  - path: \"02-Projects\"\n    description: \"Active projects\"\n    optional: false\n  - path: \"02-Projects/Active\"\n    description: \"Active projects\"\n    optional: true\n  - path: \"02-Areas\"\n    description: \"Long-term areas of responsibility\"\n    optional: false\n  - path: \"03-Knowledge\"\n    description: \"Reusable knowledge\"\n    optional: false\n  - path: \"03-Knowledge/Concepts\"\n    description: \"Concepts\"\n    optional: true\n  - path: \"03-Knowledge/How-To\"\n    description: \"How-To guides\"\n    optional: true\n  - path: \"03-Knowledge/References\"\n    description: \"References\"\n    optional: true\n  - path: \"04-Decisions\"\n    description: \"Architecture decisions\"\n    optional: false\n  - path: \"99-Archive\"\n    description: \"Completed items\"\n    optional: true\n  - path: \"00-Meta/Backups\"\n    description: \"Backup files\"\n    optional: true\n\n# Required Files\nrequired_files:\n  - path: \"_MOC-Startseite.md\"\n    description: \"Main navigation\"\n    optional: false\n  - path: \"00-Meta/Capabilities-Index.md\"\n    description: \"Skills overview\"\n    optional: false\n\n# Auto-Fix Settings\nauto_fix:\n  enabled: true\n  actions:\n    - create_missing_folders\n    - create_missing_templates\n\n# Reporting\nreport:\n  format: \"markdown\"\n  output: \"00-Meta/Backups/drift-report.md\"\n  include_recommendations: true\n'@\n\nSet-Content -Path \"C:\\Users\\andre\\.openclaw\\workspace\\SecondBrain\\00-Meta\\vault-structure.yaml\" -Value $content\nWrite-Host \"✅ drift-config.yaml übernommen als vault-structure.yaml\" -ForegroundColor Green","timeout":30}},{"type":"toolCall","id":"tool_I2sRUEQmaAKeIZIgXfm9rfjl","name":"read","arguments":{"file_path":"C:\\Users\\andre\\.openclaw\\workspace\\vault-archive\\Main_Obsidian_Vault\\Kimi_Agent_ECC-Second-Brain-Framework Implementiert\\SecondBrain\\scripts\\drift-detection.ps1","limit":50}},{"type":"toolCall","id":"tool_I2RfJuqZ7OiNfvBf1cwEYht4","name":"read","arguments":{"fil