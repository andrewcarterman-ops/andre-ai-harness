:{"kimi-coding:default":{"provider":"kimi-coding","mode":"api_key"}}},"models":{"mode":"merge","providers":{"kimi-coding":{"baseUrl":"https://api.kimi.com/coding/","api":"anthropic-messages","models":[{"id":"k2p5","name":"Kimi for Coding","reasoning":true,"input":["text","image"],"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0},"contextWindow":262144,"maxTokens":32768,"api":"anthropic-messages"}]}}},"agents":{"defaults":{"model":{"primary":"kimi-coding/k2p5","fallbacks":[]},"models":{"kimi-coding/k2p5":{}},"workspace":"C:\\Users\\andre\\.openclaw\\workspace","compaction":{"mode":"safeguard"},"timeoutSeconds":900,"sandbox":{"mode":"off"},"maxConcurrent":4,"subagents":{"maxConcurrent":8}}},"tools":{"profile":"full","web":{"search":{"enabled":true,"provider":"gemini","gemini":{"apiKey":"__OPENCLAW_REDACTED__","model":"gemini-2.5-flash"}},"fetch":{"enabled":true}},"exec":{"host":"gateway","security":"full","ask":"off","safeBinTrustedDirs":["C:\\Users\\andre\\.openclaw","C:\\Users\\andre\\.openclaw\\workspace","C:\\Users\\andre\\.openclaw\\workspace\\skills"],"applyPatch":{"enabled":true,"allowModels":["openai/*","openai-codex/*","gpt-*","claude-code/*"]}}},"commands":{"native":"auto","nativeSkills":"auto","restart":true,"ownerDisplay":"raw"},"session":{"dmScope":"per-channel-peer"},"channels":{"telegram":{"enabled":true,"dmPolicy":"pairing","botToken":"__OPENCLAW_REDACTED__","allowFrom":[8446374972],"groupPolicy":"allowlist","streaming":"partial"}},"gateway":{"port":18789,"mode":"local","bind":"lan","controlUi":{"enabled":true,"allowedOrigins":["http://localhost:18789","http://127.0.0.1:18789","http://192.168.178.192:18789","https://unserrate-le-mellifluous.ngrok-free.app","http://192.168.178.186","http://192.168.178.192:18790","http://192.168.178.192:18789"],"allowInsecureAuth":false},"auth":{"mode":"token","token":"__OPENCLAW_REDACTED__"},"tailscale":{"mode":"off","resetOnExit":false},"nodes":{"denyCommands":["camera.snap","camera.clip","screen.record","cont