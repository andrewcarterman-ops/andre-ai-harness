{"type":"message","id":"50f3c7fc","parentId":"760184eb","timestamp":"2026-04-10T20:27:50.375Z","message":{"role":"toolResult","toolCallId":"tool_szKu8v5xIRrHPGqscgCFU1SC","toolName":"read","content":[{"type":"text","text":"{\n  \"name\": \"ecc-second-brain\",\n  \"version\": \"1.0.0\",\n  \"description\": \"ECC Second Brain Framework with Obsidian Integration\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"jest\",\n    \"lint\": \"eslint scripts/\",\n    \"sync\": \"powershell -ExecutionPolicy Bypass -File ./scripts/sync-openclaw-to-obsidian.ps1\",\n    \"backup\": \"powershell -ExecutionPolicy Bypass -File ./scripts/cmd-backup.ps1\",\n    \"drift-check\": \"powershell -ExecutionPolicy Bypass -File ./scripts/drift-detection.ps1\",\n    \"setup\": \"powershell -ExecutionPolicy Bypass -File ./Setup-SecondBrain.ps1\"\n  },\n  \"keywords\": [\n    \"ecc\",\n    \"second-brain\",\n    \"obsidian\",\n    \"openclaw\",\n    \"knowledge-management\",\n    \"para-method\"\n  ],\n  \"author\": \"Andrew (andrew-main)\",\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"winston\": \"^3.11.0\",\n    \"winston-daily-rotate-file\": \"^4.7.1\",\n    \"yaml\": \"^2.3.4\",\n    \"chokidar\": \"^3.5.3\"\n  },\n  \"devDependencies\": {\n    \"jest\": \"^29.7.0\",\n    \"eslint\": \"^8.56.0\"\n  },\n  \"engines\": {\n    \"node\": \">=16.0.0\"\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/andrew/ecc-second-brain.git\"\n  },\n  \"bugs\": {\n    \"url\": \"https://github.com/andrew/ecc-second-brain/issues\"\n  },\n  \"homepage\": \"https://github.com/andrew/ecc-second-brain#readme\"\n}\n"}],"isError":false,"timestamp":1775852870369}}
