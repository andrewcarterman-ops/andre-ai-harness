{"type":"message","id":"146ff3f2","parentId":"2850edc3","timestamp":"2026-03-22T21:04:40.036Z","message":{"role":"toolResult","toolCallId":"tool_OIdwAGQo1aZVwwb2aDGvcuFl","toolName":"read","content":[{"type":"text","text":"'use client';\n\nimport { useEffect, useRef, useState } from 'react';\nimport { useActivityStore } from '@/stores/activityStore';\nimport { Activity, ActivityType } from '@/types';\nimport { \n  CheckCircle2, \n  Plus, \n  Edit3, \n  User, \n  Bot,\n  ArrowRight,\n  Archive,\n  Trash2,\n  Filter,\n  Bell,\n} from 'lucide-react';\nimport { formatDistanceToNow } from 'date-fns';\nimport { cn } from '@/lib/utils';\n\nconst activityIcons: Record<ActivityType, React.ElementType> = {\n  task_created: Plus,\n  task_completed: CheckCircle2,\n  task_updated: Edit3,\n  task_moved: ArrowRight,\n  task_assigned: User,\n  project_created: Plus,\n  project_updated: Edit3,\n  project_completed: CheckCircle2,\n  doc_created: Plus,\n  doc_updated: Edit3,\n  memory_created: Plus,\n  agent_action: Bot,\n  system_event: Archive,\n};\n\nconst activityColors: Record<ActivityType, string> = {\n  task_created: 'bg-blue-500/20 text-blue-400',\n  task_completed: 'bg-green-500/20 text-green-400',\n  task_updated: 'bg-yellow-500/20 text-yellow-400',\n  task_moved: 'bg-purple-500/20 text-purple-400',\n  task_assigned: 'bg-pink-500/20 text-pink-400',\n  project_created: 'bg-blue-500/20 text-blue-400',\n  project_updated: 'bg-yellow-500/20 text-yellow-400',\n  project_completed: 'bg-green-500/20 text-green-400',\n  doc_created: 'bg-blue-500/20 text-blue-400',\n  doc_updated: 'bg-yellow-500/20 text-yellow-400',\n  memory_created: 'bg-purple-500/20 text-purple-400',\n  agent_action: 'bg-purple-500/20 text-purple-400',\n  system_event: 'bg-gray-500/20 text-gray-400',\n};\n\nexport function ActivityFeed() {\n  const { \n    activities, \n    unreadCount, \n    filter, \n    setFilter,\n    markAsRead,\n    clearActivities,\n    getFilteredActivities,\n  } = useActivityStore();\n  const scrollRef = useRef<HTMLDivElement>(null);\n  const [showFilters, setShowFilters] = useState(false);\n\n  // Auto-scroll to top when new activity added\n  useEffect(() => {\n    if (scrollRef.current) {\n      scrollRef.current.scrollTop = 0;\n    }\n  }, [activities.length]);\n\n  const filteredActivities = getFilteredActivities();\n\n  const filters: { value: ActivityType | 'all'; label: string }[] = [\n    { value: 'all', label: 'All' },\n    { value: 'task_created', label: 'Tasks Created' },\n    { value: 'task_completed', label: 'Tasks Completed' },\n    { value: 'task_updated', label: 'Tasks Updated' },\n    { value: 'agent_action', label: 'AI Actions' },\n  ];\n\n  return (\n    <div className=\"flex flex-col h-full\">\n      {/* Header */}\n      <div className=\"flex items-center justify-between p-4 border-b border-white/[0.06]\">\n        <div className=\"flex items-center gap-2\">\n          <Bell className={cn(\n            'w-5 h-5',\n            unreadCount > 0 ? 'text-purple-400' : 'text-white/40'\n          )} />\n          <div>\n            <h3 className=\"font-medium text-white/90\">Activity Feed</h3>\n            {unreadCount > 0 && (\n              <p className=\"text-xs text-purple-400\">\n                {unreadCount} new\n              </p>\n            )}\n          </div>\n        </div>\n        \n        <div className=\"flex items-center gap-1\">\n          <button\n            onClick={() => setShowFilters(!showFilters)}\n            className={cn(\n              'p-2 rounded-lg transition-colors',\n              showFilters ? 'bg-purple-500/20 text-purple-400' : 'hover:bg-white/[0.06]'\n            )}\n            title=\"Filter\"\n          >\n            <Filter className=\"w-4 h-4\" />\n          </button>\n          \n          {unreadCount > 0 && (\n            <button\n              onClick={markAsRead}\n              className=\"px-2 py-1 text-xs bg-purple-500/20 text-purple-400 rounded hover:bg-purple-500/30 transition-colors\"\n            >\n              Mark read\n            </button>\n          )}\n          \n          {activities.length > 0 && (\n            <button\n              onClick={clearActivities}\n              className=\"p-2 hover:bg-white/[0.06] rounded transition-colors\"\n              title=\"Clear all\"\n            >\n              <Trash2 className=\"w-4 h-4 text-white/40\" />\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Filters */}\n      {showFilters && (\n        <div className=\"px-4 py-2 border-b border-white/[0.06] flex flex-wrap gap-2\">\n          {filters.map((f) => (\n            <button\n              key={f.value}\n              onClick={() => setFilter(f.value)}\n              className={cn(\n                'px-2 py-1 text-xs rounded transition-colors',\n                filter === f.value\n                  ? 'bg-purple-500 text-white'\n                  : 'bg-white/[0.04] text-white/60 hover:bg-white/[0.08]'\n              )}\n            >\n              {f.label}\n            </button>\n          ))}\n        </div>\n      )}\n\n      {/* Activity List */}\n      <div \n        ref={scrollRef}\n        className=\"flex-1 overflow-y-auto p-4 space-y-3\"\n      >\n        {filteredActivities.length === 0 ? (\n          <div className=\"text-center py-12\">\n            <Archive className=\"w-12 h-12 text-white/20 mx-auto mb-3\" />\n            <p className=\"text-white/30\">No activities yet</p>\n            <p className=\"text-white/20 text-sm mt-1\">\n              Activities will appear here when tasks are created or updated\n            </p>\n          </div>\n        ) : (\n          filteredActivities.map((activity, index) => (\n            <ActivityItem \n              key={activity.id} \n              activity={activity} \n              isUnread={index < unreadCount}\n            />\n          ))\n        )}\n      </div>\n    </div>\n  );\n}\n\nfunction ActivityItem({ \n  activity, \n  isUnread \n}: { \n  activity: Activity; \n  isUnread: boolean;\n}) {\n  const Icon = activityIcons[activity.type] || Archive;\n  const colorClass = activityColors[activity.type] || 'bg-gray-500/20 text-gray-400';\n  const isAI = activity.actor.type === 'ai';\n\n  return (\n    <div\n      className={cn(\n        'flex gap-3 p-3 rounded-lg transition-colors',\n        isUnread ? 'bg-purple-500/5' : 'hover:bg-white/[0.02]'\n      )}\n    >\n      {/* Icon */}\n      <div \n        className={cn(\n          'w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0',\n          colorClass\n        )}\n      >\n        <Icon className=\"w-4 h-4\" />\n      </div>\n\n      {/* Content */}\n      <div className=\"flex-1 min-w-0\">\n        <div className=\"flex items-start justify-between gap-2\">\n          <p className=\"text-sm text-white/80\">\n            <span className={cn(\n              'font-medium',\n              isAI ? 'text-purple-400' : 'text-blue-400'\n            )}>\n              {activity.actor.name}\n            </span>\n            {' '}{activity.action}{' '}\n            <span className=\"font-medium text-white\">{activity.targetName}</span>\n          </p>\n          \n          {isUnread && (\n            <span className=\"w-2 h-2 rounded-full bg-purple-400 flex-shrink-0 mt-1\" />\n          )}\n        </div>\n        \n        <div className=\"flex items-center gap-2 mt-1\">\n          <span className=\"text-xs text-white/30\">\n            {formatDistanceToNow(new Date(activity.timestamp), { addSuffix: true })}\n          </span>\n          {activity.metadata && Object.keys(activity.metadata).length > 0 && (\n            <span className=\"text-xs text-white/20\">\n              • {Object.keys(activity.metadata).length} detail{Object.keys(activity.metadata).length !== 1 ? 's' : ''}\n            </span>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"}],"isError":false,"timestamp":1774213480033}}
{"type":"message","id":"4b32bca3","parentId":"146ff3f2","timestamp":"2026-03-22T21:04:48.978Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The ActivityFeed component looks fine. It properly imports `useActivityStore` from `@/stores/activityStore` and uses it correctly.\n\nLooking at the error I got earlier, it was about a different file (api/docs/route.ts), not about useActivityStore. Let me check if maybe the issue is that the page file is importing ActivityFeed and KanbanBoard but those might not be the default exports, or there could be some other issue.\n\nActually, looking at the app/tasks/page.tsx more carefully, it imports:\n- `KanbanBoard` from `@/components/kanban/KanbanBoard`\n- `ActivityFeed` from `@/components/ActivityFeed`\n\nBoth are named exports, so that should be fine. Let me check if there might be an issue with the date-fns library that's used in ActivityFeed.","thinkingSignature":""},{"type":"toolCall","id":"tool_T2l8RDMj8s1ROKbhuujnQhbi","name":"exec","arguments":{"command":"cd C:\\Users\\andre\\.openclaw\\workspace\\skills\\mission-control-v2 ; Get-Content package.json | Select-String \"date-fns\""}}],"api":"anthropic-messages","provider":"kimi-coding","model":"kimi-k2-thinking","usage":{"input":2104,"output":218,"cacheRead":47360,"cacheWrite":0,"totalTokens":49682,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774213480040}}
