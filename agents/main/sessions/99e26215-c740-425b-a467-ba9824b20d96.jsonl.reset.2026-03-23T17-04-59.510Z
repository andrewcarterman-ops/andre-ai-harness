{"type":"message","id":"09f011be","parentId":"04992d39","timestamp":"2026-03-22T16:26:57.957Z","message":{"role":"toolResult","toolCallId":"tool_XY23UwwLvQxupmODD1Zvhu81","toolName":"read","content":[{"type":"text","text":"import type { Metadata } from 'next'\nimport { Inter } from 'next/font/google'\nimport './globals.css'\nimport { Toaster } from '@/components/ui/toaster'\n\nconst inter = Inter({ \n  subsets: ['latin'],\n  variable: '--font-inter',\n})\n\nexport const metadata: Metadata = {\n  title: 'Mission Control',\n  description: 'Your personal tool factory',\n}\n\nexport default function RootLayout({\n  children,\n}: {\n  children: React.ReactNode\n}) {\n  return (\n    <html lang=\"en\" className=\"dark\">\n      <body className={`${inter.className} bg-[#0a0a0a] text-white min-h-screen`}>\n        {children}\n        <Toaster />\n      </body>\n    </html>\n  )\n}\n"}],"isError":false,"timestamp":1774196817954}}
